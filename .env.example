# ─────────────────────────────────────────────────────────────
# MedCare India — Backend Environment Variables
# Copy this file to .env and fill in your real credentials.
# NEVER commit your .env file to version control!
# ─────────────────────────────────────────────────────────────

# Server port (default: 3001)
PORT=3001

# ── Gmail (Email notifications) ──────────────────────────────
# Use a Gmail account. Enable 2-Step Verification, then go to:
# Google Account → Security → App Passwords → Generate a new one
# Use that 16-character App Password below (NOT your Gmail login password)
GMAIL_USER=your_gmail@gmail.com
GMAIL_PASS=xxxx_xxxx_xxxx_xxxx

# ── Twilio (SMS notifications) ───────────────────────────────
# Sign up free at https://www.twilio.com
# Find these in your Twilio Console → Account Info
TWILIO_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# Your Twilio phone number (buy one in the Twilio console)
# For India SMS delivery, use a US number like +1XXXXXXXXXX
TWILIO_PHONE=+1XXXXXXXXXX
